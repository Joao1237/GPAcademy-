# Porta da API (Render define automaticamente)
PORT=3000

# MySQL local
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=GPAcademy_DB

# MySQL no Railway (copie do painel do serviço MySQL)
# Opção 1: URL pública (recomendado para conectar o Render)
# MYSQL_PUBLIC_URL=mysql://usuario:senha@host.railway.app:porta/railway
#
# Opção 2: variáveis individuais
# DB_HOST=host.railway.app
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=********
# DB_NAME=railway

# URLs do frontend permitidas no CORS (separadas por vírgula)
FRONTEND_URL=http://localhost:5500,https://seu-app.vercel.app
