{
    "version": 2,
    "rewrites": [{
            "source": "/api/backend/(.*)",
            "destination": "https://gpacademy-nqca.onrender.com/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/api/serve?path=/$1"
        }
    ],
    "headers": [{
        "source": "/(.*)",
        "headers": [{
            "key": "X-Content-Type-Options",
            "value": "nosniff"
        }]
    }]
}