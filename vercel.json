{
  "version": 2,
  "redirects": [
    {
      "source": "/",
      "destination": "/pages/login.html",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://SUBSTITUA-PELA-URL-DO-BACKEND.onrender.com/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
